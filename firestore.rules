rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if two users are friends via deterministic friendship doc
    function isFriend(userId1, userId2) {
      let id = userId1 < userId2 ? (userId1 + '_' + userId2) : (userId2 + '_' + userId1);
      return exists(/databases/$(database)/documents/friendships/$(id));
    }

    // User profiles - any authenticated user can read (for email lookup), only owner can write
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests
    match /friendRequests/{requestId} {
      allow read: if request.auth != null &&
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if request.auth != null &&
        resource.data.toUserId == request.auth.uid;
    }

    // Friendships - both users can read/delete
    match /friendships/{friendshipId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.userIds;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.userIds;
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.userIds;
    }

    // User data - owner can read/write, friends can read expenses and tags
    match /users/{userId}/expenses/{expenseId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && isFriend(request.auth.uid, userId);
    }

    match /users/{userId}/tags/{tagId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && isFriend(request.auth.uid, userId);
    }

    // Other user data (settings, etc.) - owner only
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
